# mcp-govern — environment variables
# Copy to .env and fill in values for your chosen backends

# Query execution backend: supabase | databricks
BACKEND=supabase

# Supabase (query execution + logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Databricks (query execution)
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=your-personal-access-token
# DATABRICKS_WAREHOUSE_ID=your-sql-warehouse-id

# Logging backend: file | supabase | postgres | databricks
LOG_BACKEND=file

# Supabase logging (defaults to SUPABASE_URL/KEY if not set separately)
# SUPABASE_LOG_URL=https://your-log-project.supabase.co
# SUPABASE_LOG_KEY=your-service-role-key

# Postgres logging
# POSTGRES_LOG_URL=postgresql://user:password@host:5432/dbname

# Databricks logging
# DATABRICKS_LOG_CATALOG=governance
# DATABRICKS_LOG_SCHEMA=mcp_govern
# DATABRICKS_LOG_TABLE=query_logs

# Security — set this and add as request header in Claude.ai connector config
# WEBHOOK_SECRET=your-secret-here

PORT=3000
